{
    "_comment": "Declarative UI definition for the OrcaSlicer Profile Generator GUI. The GUI (gui.py) renders itself entirely from this file - it contains NO hard-coded printers, filaments, or options. To expose a new printer, filament, or option, add an entry here; no Python changes are needed. Current values are persisted separately in config.json; the 'default' fields below are only used on first run when no saved value exists.",
    "app": {
        "title": "OrcaSlicer Profile Generator",
        "subtitle": "Algorithmic process / machine / filament profiles for Bambu Lab, Anycubic, and Elegoo printers",
        "version": "1.0.0"
    },
    "groups": [
        {
            "id": "printers",
            "title": "Printers",
            "help": "Enable the printer(s) you own. Profiles are generated for every enabled printer across its available nozzle sizes. Anycubic models inherit each printer's default OrcaSlicer start/end gcode but otherwise mirror their Bambu counterpart: enclosed models mirror the X1C, open-frame models mirror the A1.",
            "type": "toggles",
            "config_key": "ENABLED_PRINTERS",
            "columns": 2,
            "options": [
                {"key": "X1C", "label": "Bambu X1 Carbon", "help": "Enclosed CoreXY, hardened nozzle, lidar", "default": true},
                {"key": "X1",  "label": "Bambu X1",        "help": "Enclosed CoreXY, stainless nozzle, lidar", "default": false},
                {"key": "X1E", "label": "Bambu X1E",       "help": "Enclosed CoreXY, enterprise, air filtration", "default": false},
                {"key": "P1S", "label": "Bambu P1S",       "help": "Enclosed CoreXY, no lidar", "default": false},
                {"key": "P1P", "label": "Bambu P1P",       "help": "Open-frame CoreXY, no enclosure", "default": false},
                {"key": "A1",  "label": "Bambu A1",        "help": "i3 gantry, 256mm bed", "default": false},
                {"key": "A1M", "label": "Bambu A1 Mini",   "help": "i3 gantry, 180mm bed", "default": false},
                {"key": "Kobra3",     "label": "Anycubic Kobra 3",     "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "Kobra3Max",  "label": "Anycubic Kobra 3 Max", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "KobraS1",    "label": "Anycubic Kobra S1",    "help": "Enclosed CoreXY - mirrors X1C (nozzle 0.4)", "default": false},
                {"key": "KobraS1Max", "label": "Anycubic Kobra S1 Max","help": "Enclosed CoreXY - mirrors X1C (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "KobraX",     "label": "Anycubic Kobra X",     "help": "Open-frame bedslinger - mirrors A1 (nozzle 0.4)", "default": false},
                {"key": "Centauri", "label": "Elegoo Centauri", "help": "Enclosed CoreXY - mirrors X1C (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "CentauriCarbon", "label": "Elegoo Centauri Carbon", "help": "Enclosed CoreXY - mirrors X1C (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "CentauriCarbon2", "label": "Elegoo Centauri Carbon 2", "help": "Enclosed CoreXY - mirrors X1C (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune", "label": "Elegoo Neptune", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "Neptune2", "label": "Elegoo Neptune 2", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "Neptune2D", "label": "Elegoo Neptune 2D", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "Neptune2S", "label": "Elegoo Neptune 2S", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "Neptune3", "label": "Elegoo Neptune 3", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "Neptune3Max", "label": "Elegoo Neptune 3 Max", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune3Plus", "label": "Elegoo Neptune 3 Plus", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune3Pro", "label": "Elegoo Neptune 3 Pro", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune4", "label": "Elegoo Neptune 4", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune4Max", "label": "Elegoo Neptune 4 Max", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune4Plus", "label": "Elegoo Neptune 4 Plus", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "Neptune4Pro", "label": "Elegoo Neptune 4 Pro", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.2/0.4/0.6/0.8)", "default": false},
                {"key": "NeptuneX", "label": "Elegoo Neptune X", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false},
                {"key": "OrangeStormGiga", "label": "Elegoo OrangeStorm Giga", "help": "Open-frame bedslinger - mirrors A1 (nozzles 0.4/0.6/0.8)", "default": false}
            ]
        },
        {
            "id": "filaments",
            "title": "Optional Filaments",
            "help": "Core filaments (PLA, PETG, ABS) are always generated. Toggle the specialty filaments you use.",
            "type": "toggles",
            "config_key": "OPTIONAL_FILAMENTS",
            "columns": 2,
            "options": [
                {"key": "PLA Silk", "label": "PLA Silk", "help": "Shimmer PLA - own process profile (low accel)", "default": true},
                {"key": "PLA Wood", "label": "PLA Wood", "help": "Wood-fill PLA - uses PLA process, low volumetric speed", "default": false},
                {"key": "PLA-CF",   "label": "PLA-CF",   "help": "Carbon fiber PLA - uses PLA process, needs hardened nozzle", "default": false},
                {"key": "ASA",      "label": "ASA",      "help": "UV-resistant ABS alternative - enclosure required", "default": false},
                {"key": "TPU",      "label": "TPU",      "help": "Flexible - own process profile (very slow)", "default": false},
                {"key": "PVA",      "label": "PVA",      "help": "Dissolvable support interface - requires AMS", "default": true},
                {"key": "BVOH",     "label": "BVOH",     "help": "Dissolvable support - better than PVA, works with PETG, requires AMS", "default": false}
            ]
        },
        {
            "id": "output",
            "title": "Output & Options",
            "help": "Where to write the generated profiles and how to run.",
            "type": "fields",
            "fields": [
                {
                    "key": "output_mode",
                    "type": "choice",
                    "label": "Write profiles to",
                    "help": "'OrcaSlicer config' writes into your live OrcaSlicer user profiles (a timestamped backup is always taken first). 'Custom folder' writes a standalone copy and never touches OrcaSlicer.",
                    "default": "orcaslicer",
                    "choices": [
                        {"value": "orcaslicer", "label": "OrcaSlicer config (live)"},
                        {"value": "custom",     "label": "Custom folder…"}
                    ]
                },
                {
                    "key": "output_dir",
                    "type": "directory",
                    "label": "Custom output folder",
                    "help": "Folder to write the process / machine / filament subfolders into.",
                    "default": "",
                    "visible_when": {"field": "output_mode", "equals": "custom"}
                },
                {
                    "key": "do_clean",
                    "type": "bool",
                    "label": "Clean existing generated profiles first",
                    "help": "Delete all previously generated 'B' profiles before writing. A backup is always taken first. Use this for a full reset.",
                    "default": false
                },
                {
                    "key": "dry_run",
                    "type": "bool",
                    "label": "Dry run (preview only - write nothing)",
                    "help": "Run the full generation and report what would happen without writing or deleting any files.",
                    "default": false
                }
            ]
        }
    ]
}
